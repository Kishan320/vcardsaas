<template>
  <div class="cafe-template" :style="{ fontFamily: font, direction: isRTL ? 'rtl' : 'ltr' }">
    <template v-for="sectionKey in orderedSections" :key="sectionKey">
      <component :is="renderSection(sectionKey)" />
    </template>
    <QRShareModal v-if="showQrModal" @close="showQrModal = false" :data="data" :colors="colors" />
  </div>
</template>

<script setup lang="ts">
import { ref, computed, onMounted } from 'vue';
import { useI18n } from 'vue-i18n';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Mail, Phone, Globe, MapPin, Coffee, QrCode, Clock } from 'lucide-vue-next';
import SocialIcon from '@/pages/link-bio-builder/components/SocialIcon.vue';
import { QRShareModal } from '@/components/QRShareModal.vue';
import { getSectionOrder } from '@/utils/sectionHelpers';
import { getBusinessTemplate } from '@/pages/vcard-builder/business-templates';

interface CafeTemplateProps {
  data: any;
  template: any;
}

const props = defineProps<CafeTemplateProps>();
const { t } = useI18n();

const configSections = computed(() => props.data.config_sections || {});
const colors = computed(() => ({ 
  ...props.template?.defaultColors, 
  ...configSections.value.colors 
}) || { 
  primary: '#92400E', 
  secondary: '#78350F', 
  accent: '#F59E0B', 
  text: '#E2E8F0',
  background: '#451A03',
  borderColor: '#78350F',
  codeBlock: '#292524',
  syntaxHighlight: '#FED7AA'
});

const font = computed(() => configSections.value.font || props.template?.defaultFont || 'Inter, sans-serif');
const currentLanguage = ref(configSections.value.language?.template_language || 'en');
const showQrModal = ref(false);
const rtlLanguages = ['ar', 'he'];
const isRTL = computed(() => rtlLanguages.includes(currentLanguage.value));
const allSections = computed(() => getBusinessTemplate('cafe')?.sections || []);
const orderedSections = computed(() => getSectionOrder(configSections.value, allSections.value));

const renderSection = (sectionKey: string) => {
  const sectionData = configSections.value[sectionKey] || {};
  if (!sectionData || Object.keys(sectionData).length === 0 || sectionData.enabled === false) return null;
  
  switch (sectionKey) {
    case 'header': return renderHeaderSection(sectionData);
    case 'contact': return renderContactSection(sectionData);
    case 'about': return renderAboutSection(sectionData);
    case 'menu': return renderMenuSection(sectionData);
    case 'social': return renderSocialSection(sectionData);
    case 'business_hours': return renderBusinessHoursSection(sectionData);
    case 'qr_share': return renderQrShareSection(sectionData);
    default: return null;
  }
};

const renderHeaderSection = (headerData: any) => (
  <div class="relative rounded-t-2xl overflow-hidden" :style="{ background: colors.value.background || '#451A03' }">
    <div class="absolute inset-0 opacity-10">
      <svg viewBox="0 0 200 200" class="w-full h-full">
        <pattern id="cafe" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
          <circle cx="20" cy="20" r="8" :stroke="colors.value.primary" stroke-width="2" fill="none" />
          <path d="M20,12 L20,20 M16,16 L24,16" :stroke="colors.value.primary" stroke-width="2" />
        </pattern>
        <rect width="100%" height="100%" fill="url(#cafe)" />
      </svg>
    </div>
    <div class="relative px-6 py-8 text-center">
      {headerData.profile_image && (
        <div class="w-24 h-24 mx-auto mb-4 rounded-full overflow-hidden border-4" :style="{ borderColor: colors.value.primary }">
          <img :src="headerData.profile_image" :alt="headerData.name || 'Cafe'" class="w-full h-full object-cover" />
        </div>
      )}
      <div class="flex items-center justify-center gap-2 mb-2">
        <Coffee class="w-6 h-6" :style="{ color: colors.value.primary }" />
        <h1 class="text-2xl font-bold" :style="{ color: colors.value.primary }">
          {{ headerData.name || props.data.name || '' }}
        </h1>
      </div>
      {headerData.coffee_type && (
        <Badge class="mb-4" :style="{ backgroundColor: colors.value.primary, color: 'white' }">
          {{ headerData.coffee_type }}
        </Badge>
      )}
      {headerData.tagline && (
        <p class="text-sm mb-4 italic" :style="{ color: colors.value.text, fontFamily: font.value }">
          "{{ headerData.tagline }}"
        </p>
      )}
    </div>
  </div>
);

const renderContactSection = (contactData: any) => {
  if (!contactData.email && !contactData.phone && !contactData.website && !contactData.location) return null;
  
  return (
    <div class="px-6 py-4" :style="{ borderBottom: `1px solid ${colors.value.borderColor || '#78350F'}` }">
      <h3 class="font-bold text-sm mb-4" :style="{ color: colors.value.primary, fontFamily: font.value }">Contact</h3>
      <div class="space-y-3">
        {contactData.phone && (
          <a :href="`tel:${contactData.phone}`" class="flex items-center gap-3 text-sm hover:opacity-80" :style="{ color: colors.value.text, fontFamily: font.value }">
            <Phone class="w-4 h-4" :style="{ color: colors.value.primary }" />
            {contactData.phone}
          </a>
        )}
        {contactData.email && (
          <a :href="`mailto:${contactData.email}`" class="flex items-center gap-3 text-sm hover:opacity-80" :style="{ color: colors.value.text, fontFamily: font.value }">
            <Mail class="w-4 h-4" :style="{ color: colors.value.primary }" />
            {contactData.email}
          </a>
        )}
        {contactData.location && (
          <div class="flex items-center gap-3 text-sm" :style="{ color: colors.value.text, fontFamily: font.value }">
            <MapPin class="w-4 h-4" :style="{ color: colors.value.primary }" />
            {contactData.location}
          </div>
        )}
      </div>
    </div>
  );
};

const renderMenuSection = (menuData: any) => {
  if (!menuData.menu_items || menuData.menu_items.length === 0) return null;
  
  return (
    <div class="px-6 py-4" :style="{ borderBottom: `1px solid ${colors.value.borderColor || '#78350F'}` }">
      <h3 class="font-bold text-sm mb-4" :style="{ color: colors.value.primary, fontFamily: font.value }">Menu</h3>
      <div class="space-y-3">
        {menuData.menu_items.map((item: any, index: number) => (
          <div :key="index" class="p-3 rounded-lg" :style="{ backgroundColor: colors.value.codeBlock, color: colors.value.text, fontFamily: font.value }">
            <div class="flex justify-between items-start">
              <div class="flex-1">
                <div class="font-semibold" :style="{ color: colors.value.primary }">{{ item.name }}</div>
                {item.description ? (
                  <div class="text-xs mt-1" :style="{ color: colors.value.text + 'CC' }">{{ item.description }}</div>
                ) : null}
              </div>
              {item.price ? (
                <div class="ml-3 font-bold" :style="{ color: colors.value.primary }}">${item.price}</div>
              ) : null}
            </div>
          </div>
        ))}
      </div>
    </div>
  );
};

const renderBusinessHoursSection = (hoursData: any) => {
  if (!hoursData.business_hours) return null;
  
  return (
    <div class="px-6 py-4" :style="{ borderBottom: `1px solid ${colors.value.borderColor || '#78350F'}` }">
      <h3 class="font-bold text-sm mb-4 flex items-center gap-2" :style="{ color: colors.value.primary, fontFamily: font.value }">
        <Clock class="w-4 h-4" />
        Hours
      </h3>
      <div class="space-y-2 text-sm" :style="{ color: colors.value.text, fontFamily: font.value }">
        {Object.entries(hoursData.business_hours).map(([day, hours]: [string, string]) => (
          <div :key="day" class="flex justify-between">
            <span :style="{ color: colors.value.primary }">{{ day }}:</span>
            <span>{{ hours }}</span>
          </div>
        ))}
      </div>
    </div>
  );
};

const renderAboutSection = (aboutData: any) => {
  if (!aboutData.description) return null;
  
  return (
    <div class="px-6 py-4" :style="{ borderBottom: `1px solid ${colors.value.borderColor || '#78350F'}` }">
      <h3 class="font-bold text-sm mb-4" :style="{ color: colors.value.primary, fontFamily: font.value }">About</h3>
      <div class="p-3 rounded-lg text-sm leading-relaxed" :style="{ backgroundColor: colors.value.codeBlock, color: colors.value.text, fontFamily: font.value }">
        {aboutData.description}
      </div>
    </div>
  );
};

const renderSocialSection = (socialData: any) => {
  if (!socialData.platforms || socialData.platforms.length === 0) return null;
  
  return (
    <div class="px-6 py-4" :style="{ borderBottom: `1px solid ${colors.value.borderColor || '#78350F'}` }">
      <h3 class="font-bold text-sm mb-4" :style="{ color: colors.value.primary, fontFamily: font.value }">Follow</h3>
      <div class="flex flex-wrap gap-3">
        {socialData.platforms.map((platform: any, index: number) => (
          <a :key="index" :href="platform.url" target="_blank" class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm hover:opacity-80" :style="{ backgroundColor: colors.value.codeBlock, color: colors.value.text, fontFamily: font.value }">
            <SocialIcon :platform="platform.name" class="w-4 h-4" :style="{ color: colors.value.primary }" />
            <span>{{ platform.name }}</span>
          </a>
        ))}
      </div>
    </div>
  );
};

const renderQrShareSection = (qrData: any) => {
  if (!qrData.enable_qr) return null;
  
  return (
    <div class="px-6 py-4" :style="{ borderBottom: `1px solid ${colors.value.borderColor || '#78350F'}` }">
      <h3 class="font-bold text-sm mb-4" :style="{ color: colors.value.primary, fontFamily: font.value }">Share</h3>
      <Button size="sm" class="w-full" :style="{ backgroundColor: colors.value.primary, color: 'white', fontFamily: font.value }" @click="showQrModal = true">
        <QrCode class={`w-4 h-4 ${isRTL.value ? 'ml-2' : 'mr-2'}`} />
        Share Cafe
      </Button>
    </div>
  );
};

onMounted(() => {
  currentLanguage.value = configSections.value.language?.template_language || 'en';
});
</script>

<style scoped>
.cafe-template {
  width: 100%;
  max-width: 400px;
  margin: 0 auto;
  background: #451A03;
  border-radius: 1rem;
  overflow: hidden;
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
}
</style>
